rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is a dealer
    function isDealer() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dealer';
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Role audit log collection - only accessible through Admin SDK
    match /roleAuditLog/{logId} {
      allow read, write: if false; // Restrict direct access, only allow through Admin SDK
    }

    // Advertisements collection
    match /advertisements/{advertisementId} {
      allow read: if true; // Anyone can read advertisements
      allow create: if isDealer() && 
        request.resource.data.dealerId == request.auth.uid;
      allow update: if isDealer() && 
        resource.data.dealerId == request.auth.uid;
      allow delete: if isDealer() && 
        resource.data.dealerId == request.auth.uid;
    }
  }
} 